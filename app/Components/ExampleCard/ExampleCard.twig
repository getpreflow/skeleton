{% apply css %}
{# Auto-scoped to .example-card-{hash} via native CSS nesting #}
padding: 2rem;
border-radius: 0.5rem;
background: #f8f9fa;
max-width: 24rem;
font-family: system-ui, sans-serif;

h2 {
    margin: 0 0 0.5rem;
    color: #333;
}

p {
    color: #555;
    margin: 0 0 0.25rem;
}

button {
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0.25rem;
    background: #0066ff;
    color: white;
    cursor: pointer;
    font-size: 1rem;
}

button:hover {
    background: #0052cc;
}
{% endapply %}

<h2>{{ title }}</h2>
<p>{{ message }}</p>
<p>Count: {{ count }}</p>
<button {{ hd.post('increment', componentClass, componentId, props) | raw }}>+1</button>
