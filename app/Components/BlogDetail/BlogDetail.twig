{% apply css %}
.post-detail {
    max-width: 680px;
}

.post-detail h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
}

.post-detail .post-body {
    color: #444;
    line-height: 1.8;
    font-size: 1.0625rem;
}

.post-detail .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: #0066ff;
    text-decoration: none;
    font-size: 0.875rem;
}

.post-detail .back-link:hover {
    text-decoration: underline;
}

.post-not-found {
    text-align: center;
    padding: 3rem;
    color: #999;
}
{% endapply %}

{% if post %}
<div class="post-detail">
    <a href="/blog" class="back-link">← {{ t('blog.back') }}</a>
    <h1>{{ post.title }}</h1>
    <div class="post-body">
        {{ post.body }}
    </div>
</div>
{% else %}
<div class="post-not-found">
    <p>Post not found.</p>
    <a href="/blog" class="back-link">← {{ t('blog.back') }}</a>
</div>
{% endif %}
