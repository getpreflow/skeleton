{% extends "_layout.twig" %}

{% block title %}{{ t('blog.title') }} — Preflow App{% endblock %}

{% block content %}
{% apply css %}
.blog-header {
    margin-bottom: 2rem;
}

.blog-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
}

.blog-header p {
    color: #666;
}
{% endapply %}

<div class="blog-header">
    <h1>{{ t('blog.title') }}</h1>
    <p>{{ t('blog.subtitle') }}</p>
</div>

{{ component('BlogGrid') }}
{% endblock %}
