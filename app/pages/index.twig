{% extends "_layout.twig" %}

{% block title %}Home — Preflow App{% endblock %}

{% block content %}
{% apply css %}
.hero {
    text-align: center;
    padding: 3rem 0 2rem;
}

.hero h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
}

.hero-subtitle {
    color: #666;
    font-size: 1.25rem;
    margin-top: 0.5rem;
}

.features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
}

.feature {
    padding: 1.5rem;
    background: #f8f9fa;
    border-radius: 0.5rem;
}

.feature h3 {
    margin-bottom: 0.5rem;
    font-size: 1rem;
}

.feature p {
    color: #666;
    font-size: 0.875rem;
}
{% endapply %}

<div class="hero">
    <h1>Preflow</h1>
    <p class="hero-subtitle">HTML over the wire. No build step. No JS framework.</p>
</div>

{{ component('ExampleCard', {
    title: 'Hello, Preflow',
    message: 'This component has co-located CSS, JS, and a working HTMX counter.'
}) }}

<div class="features">
    <div class="feature">
        <h3>Components</h3>
        <p>Co-located PHP + Twig + CSS + JS. Drop a directory, it works.</p>
    </div>
    <div class="feature">
        <h3>Zero Requests</h3>
        <p>All CSS and JS inline in the HTML. Hash-deduplicated. CSP nonces.</p>
    </div>
    <div class="feature">
        <h3>Hypermedia</h3>
        <p>HTMX-driven interactivity with signed component tokens.</p>
    </div>
</div>
{% endblock %}
